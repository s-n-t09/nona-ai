rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - displayName: string (required) - User's chosen display name
    //   - dateOfBirth: string (required) - User's date of birth (YYYY-MM-DD)
    //   - isAdult: boolean (required) - Whether the user is 18 or older
    //   - settings: map (required) - { showNsfw: bool, theme: string }
    //   - createdAt: string (required) - Timestamp
    //
    // Collection: characters
    // Document ID: {characterId}
    // Fields:
    //   - creatorId: string (required) - UID of the user who created this character
    //   - name: string (required) - Character's name
    //   - description: string (required) - Short description
    //   - imageUrl: string (optional) - URL to character's avatar image
    //   - prompt: string (required) - System prompt defining the character's personality
    //   - isPublic: boolean (required) - Whether the character is visible to everyone
    //   - isNsfw: boolean (required) - Whether the character contains NSFW content
    //   - createdAt: string (required) - Timestamp
    //
    // Collection: chats
    // Document ID: {chatId}
    // Fields:
    //   - userId: string (required) - UID of the user
    //   - characterId: string (required) - ID of the character
    //   - createdAt: string (required) - Timestamp
    //   - updatedAt: string (required) - Timestamp
    //
    // Collection: chats/{chatId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - role: string (required) - "user" or "assistant"
    //   - content: string (required) - The message text
    //   - createdAt: string (required) - Timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}.*$");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasRequiredFields(['uid', 'displayName', 'dateOfBirth', 'isAdult', 'settings', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             isValidDateString(data.dateOfBirth) &&
             data.isAdult is bool &&
             data.settings is map &&
             data.settings.showNsfw is bool &&
             data.settings.theme in ['dark', 'light'] &&
             data.createdAt is string;
    }

    function isValidCharacter(data) {
      return hasRequiredFields(['creatorId', 'name', 'description', 'prompt', 'isPublic', 'isNsfw', 'createdAt']) &&
             data.creatorId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             data.prompt is string && data.prompt.size() > 0 && data.prompt.size() < 5000 &&
             data.isPublic is bool &&
             data.isNsfw is bool &&
             data.createdAt is string &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000));
    }

    function isValidChat(data) {
      return hasRequiredFields(['userId', 'characterId', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.characterId is string &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidMessage(data) {
      return hasRequiredFields(['role', 'content', 'createdAt']) &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow reading other users' display names
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;
      allow delete: if false; // Don't allow deletion for now
    }

    match /characters/{characterId} {
      // Anyone authenticated can read public characters.
      // To read NSFW characters, the user must be an adult.
      // A user can always read their own characters.
      allow read: if isAuthenticated() && (
        (resource.data.isPublic == true && (resource.data.isNsfw == false || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdult == true)) ||
        resource.data.creatorId == request.auth.uid
      );
      allow create: if isAuthenticated() && isValidCharacter(request.resource.data);
      allow update: if isAuthenticated() && resource.data.creatorId == request.auth.uid && 
                    isValidCharacter(request.resource.data) &&
                    request.resource.data.creatorId == resource.data.creatorId;
      allow delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && 
                    isValidChat(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.characterId == resource.data.characterId;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      match /messages/{messageId} {
        // Can only read/write messages if they own the parent chat
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        allow create: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid &&
                      isValidMessage(request.resource.data);
        allow update: if false; // Messages shouldn't be updated
        allow delete: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      }
    }
  }
}
